<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog title="Cancel E-Way Bill" id="idWayCancelDialog">

        <VBox class="sapUiSmallMargin">

            <Label text="Cancel Reason"/>
            <Select id="idEwayCancelReason">

                <items>
                    <core:Item key="1" text="Duplicate"/>
                    <core:Item key="2" text="Order Cancelled"/>
                    <core:Item key="3" text="Data Entry mistake"/>
                    <core:Item key="4" text="Others"/>
                </items>

            </Select>

            <!-- <Label text="Cancel Remark" class="sapUiSmallMarginTop"/>
            <Input id="idCancelRemark"/> -->

        </VBox>

        <beginButton>
            <Button text="OK" press="onConfirmEwayCancel"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press="onCloseCancelDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>